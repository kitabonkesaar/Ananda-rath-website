# ── Convex Backend ──────────────────────────────────────────────────────────────
# Copy your Convex deployment URL here (from .env or Convex dashboard)
NEXT_PUBLIC_CONVEX_URL=https://your-deployment.convex.cloud

# ── Admin Credentials (optional override) ───────────────────────────────────────
# NOTE: NEXT_PUBLIC_ vars are exposed to the browser. For production, implement
# proper server-side authentication instead of these env vars.
NEXT_PUBLIC_ADMIN_EMAIL=admin@anandarath.com
NEXT_PUBLIC_ADMIN_PASSWORD=admin123
